HOMEFLIX_ENV=development
LOG_LEVEL=info

POSTGRES_HOST=localhost
# Family V1: un único PostgreSQL local.
POSTGRES_PORT=5432
POSTGRES_DB=homeflix
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/homeflix

# Monolito Family V1: JWT firmado en cookies HTTP-only (mínimo 32 caracteres).
FAMILY_JWT_SECRET=change-me-please-32-characters-minimum-v1

# Upload local Family V1.
FAMILY_STORAGE_ROOT=public/storage
