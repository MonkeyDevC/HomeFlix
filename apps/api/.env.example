HOMEFLIX_ENV=development
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
CLIENT_ORIGIN=http://localhost:3000
CMS_PUBLIC_URL=http://localhost:8055
DATABASE_URL=postgres://homeflix:homeflix_dev_password@localhost:5432/homeflix

# Mux: la API carga ../../.env y luego este archivo con override: true.
# No dejes MUX_TOKEN_* vacíos aquí si ya los definiste en la raíz — un = sin valor
# sobrescribe y readOptionalEnv trata "" como "no configurado".
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
MUX_TEST_UPLOADS=true
