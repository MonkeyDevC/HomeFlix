{
  "name": "@homeflix/client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "build": "prisma generate && next build",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "dev": "next dev",
    "start": "next start",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@homeflix/contracts": "workspace:*",
    "@homeflix/domain": "workspace:*",
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "bcryptjs": "3.0.2",
    "dotenv": "17.4.2",
    "ffmpeg-static": "5.2.0",
    "ffprobe-static": "^3.1.0",
    "jose": "6.0.10",
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sileo": "^0.1.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/ffprobe-static": "^2.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "7.7.0",
    "tsx": "4.19.4",
    "typescript": "^5.9.0"
  }
}
