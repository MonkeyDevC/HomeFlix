# =========================================================================
# HomeFlix Family V1 â€” plantilla de variables para despliegue en VPS.
#
# Uso:
#   1. Copiar a `.env.production` en el servidor (ese archivo NO se versiona).
#   2. Cambiar TODOS los valores `change_me_*`.
#   3. Lanzar: `docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build`
#
# Reglas:
#   - No incluir variables que el monolito no use realmente.
#   - POSTGRES_PASSWORD debe ir URL-encoded dentro de DATABASE_URL si tiene
#     caracteres especiales (ej.  `@` -> `%40`, `*` -> `%2A`).
# =========================================================================

# -------------------- PostgreSQL (servicio `postgres`) --------------------
POSTGRES_DB=homeflix
POSTGRES_USER=homeflix
POSTGRES_PASSWORD=change_me_strong_password

# -------------------- ConexiĂłn Prisma (servicio `client`) -----------------
# Host = nombre del servicio Docker (`postgres`), puerto interno 5432.
# NO usar `localhost` acĂˇ: desde el contenedor del client no resuelve al host.
DATABASE_URL=postgresql://homeflix:change_me_strong_password@postgres:5432/homeflix

# -------------------- Auth / cookies (HS256 â‰Ą 32 chars) -------------------
# Generar con: `openssl rand -base64 48`
FAMILY_JWT_SECRET=change_me_generate_with_openssl_rand_base64_48

# -------------------- Almacenamiento de media -----------------------------
# En Docker Compose, el default ya es absoluto (/repo/apps/client/public/storage)
# y debe coincidir con el volumen `homeflix-media`. Si definĂ­s esta variable,
# usĂˇ la misma ruta absoluta dentro del contenedor.
FAMILY_STORAGE_ROOT=/repo/apps/client/public/storage

# -------------------- Runtime ---------------------------------------------
NODE_ENV=production
LOG_LEVEL=info

# -------------------- Nginx (expuesto al host) ----------------------------
# Si el VPS ya tiene algo en el 80/443, cambia a otros puertos y apunta el DNS
# al puerto que decidas exponer (o ponlo detrĂˇs de un balanceador externo).
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -------------------- Bootstrap admin (manual, NO lo lee compose) ----------
# Crear el primer admin tras el primer deploy (una sola vez), vĂ­a:
#   docker compose ... exec -e HOMEFLIX_BOOTSTRAP_ADMIN_EMAIL=... \
#     -e HOMEFLIX_BOOTSTRAP_ADMIN_PASSWORD=... client \
#     sh -lc 'cd /repo/apps/client && pnpm exec tsx prisma/bootstrap-admin.ts'
# Ver docs/deploy-production.md. No definas estas variables en el mismo archivo
# si prefieres pasarlas solo en la lĂ­nea de comando (-e) para no persistirlas en disco.
# HOMEFLIX_BOOTSTRAP_ADMIN_EMAIL=admin@tu-dominio.com
# HOMEFLIX_BOOTSTRAP_ADMIN_PASSWORD=pon_aqui_una_clave_larga
# HOMEFLIX_BOOTSTRAP_RESET_PASSWORD=1   # opcional: rotar clave si el email ya existe
